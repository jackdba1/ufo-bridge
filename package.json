{
  "name": "ufo-bridge",
  "version": "1.0.0",
  "description": "⬡ UFO² COMMAND BRIDGE — Biopunk desktop agent terminal",
  "main": "main.js",
  "scripts": {
    "start": "node_modules\\electron\\dist\\electron.exe .",
    "dev": "node_modules\\electron\\dist\\electron.exe . --dev",
    "build": "electron-builder",
    "dist": "electron-builder --win portable"
  },
  "build": {
    "appId": "com.jackbabu.ufo-bridge",
    "productName": "UFO2 Bridge",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**",
      "server/**",
      "assets/**",
      "node_modules/**"
    ],
    "win": {
      "target": [
        "portable"
      ],
      "icon": "assets/icon.png"
    }
  },
  "devDependencies": {
    "electron": "^36.9.5",
    "electron-builder": "^26.0.0"
  }
}
